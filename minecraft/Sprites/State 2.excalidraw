    {
      "id": "P6IM3rbMLVw0uhYahAlHJ",
      "type": "text",
      "x": -97,
      "y": 264.75,
      "width": 659.3995361328125,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "OGTdicP3mjCmGq8tBU_ib"
      ],
      "frameId": null,
      "index": "aP",
      "roundness": null,
      "seed": 1911650491,
      "version": 240,
      "versionNonce": 1733638101,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1766009706501,
      "link": null,
      "locked": false,
      "text": "Manages a 16x16x16 block region:\n\nposition - chunk world position (in chunk coordinates)\nchunk_data - Dictionary of Cubes (keyed by local Vector3 position)\nchunk_build_data - mesh arrays (vertices, normals, UVs, indices)\ncollision_faces - packed array of collision triangles\nmesh_instance - the visual mesh\nstatic_body - StaticBody3D for physics collision\ngenerated / loaded - state flags",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Manages a 16x16x16 block region:\n\nposition - chunk world position (in chunk coordinates)\nchunk_data - Dictionary of Cubes (keyed by local Vector3 position)\nchunk_build_data - mesh arrays (vertices, normals, UVs, indices)\ncollision_faces - packed array of collision triangles\nmesh_instance - the visual mesh\nstatic_body - StaticBody3D for physics collision\ngenerated / loaded - state flags",
      "autoResize": true,
      "lineHeight": 1.25
    },
