      "link": null,
      "locked": false,
      "text": "_process_queues():\nif gen_thread == null and not chunks_to_generate.is_empty():\n    var next_chunk = chunks_to_generate.pop_front()\n    spacer_generation(next_chunk.position)\n        \n# Start loading thread if idle and work available\nif load_thread == null and not chunks_to_load.is_empty():\n    var next_chunk = chunks_to_load.pop_front()\n    spacer_loading(next_chunk.position)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "_process_queues():\nif gen_thread == null and not chunks_to_generate.is_empty():\n    var next_chunk = chunks_to_generate.pop_front()\n    spacer_generation(next_chunk.position)\n        \n# Start loading thread if idle and work available\nif load_thread == null and not chunks_to_load.is_empty():\n    var next_chunk = chunks_to_load.pop_front()\n    spacer_loading(next_chunk.position)",
