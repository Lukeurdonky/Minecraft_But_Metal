    {
      "id": "7_GBCui_ded3OwA3Th3Ws",
      "type": "text",
      "x": 6826.169161911773,
      "y": 4974.606341268476,
      "width": 751.9993896484375,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "0HMsPg_Q97ffkfmW4NxQY"
      ],
      "frameId": null,
      "index": "b1d",
      "roundness": null,
      "seed": 628358342,
      "version": 234,
      "versionNonce": 1429707674,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1766394381607,
      "link": null,
      "locked": false,
      "text": "func generate_chunk_geometry():\n    var mesh_data = []  # Temporary array for this function\n    var collision_data = []  # Temporary array for this function\n    \n    for each block:\n        for each face:\n            if face_is_exposed_to_air():\n                # Add face to mesh data\n                mesh_data.append(face_vertices)\n                \n                # Add same face to collision data\n                collision_data.append(face_collision_shape)\n    \n    # Now create the actual objects\n    mesh_instance.mesh = create_mesh_from_data(mesh_data)\n    collision_body.shape = create_collision_from_data(collision_data)\n    \n    # mesh_data and collision_data arrays are discarded after function ends",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "func generate_chunk_geometry():\n    var mesh_data = []  # Temporary array for this function\n    var collision_data = []  # Temporary array for this function\n    \n    for each block:\n        for each face:\n            if face_is_exposed_to_air():\n                # Add face to mesh data\n                mesh_data.append(face_vertices)\n                \n                # Add same face to collision data\n                collision_data.append(face_collision_shape)\n    \n    # Now create the actual objects\n    mesh_instance.mesh = create_mesh_from_data(mesh_data)\n    collision_body.shape = create_collision_from_data(collision_data)\n    \n    # mesh_data and collision_data arrays are discarded after function ends",
      "autoResize": true,
      "lineHeight": 1.25
    },
