    {
      "id": "7fikz4DaT1qGbDVZ2Btt1",
      "type": "rectangle",
      "x": 6874.564531124951,
      "y": 4064.0564952756094,
      "width": 593.333333333333,
      "height": 694.9999999999989,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
