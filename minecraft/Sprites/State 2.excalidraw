    {
      "id": "TRTgusZ_yfIIzk31zNZjk",
      "type": "text",
      "x": 3535.5858964677495,
      "y": 169.3784800476891,
      "width": 2048.958740234375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
