    {
      "id": "2SECDyGKvIfYNc6cpoMV2",
      "type": "text",
      "x": 6886.231197791619,
      "y": 4077.3898286089425,
      "width": 566.8153505798772,
      "height": 655.7692307692313,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "Cxo2AwLk8zVck6c0qspwW"
      ],
      "frameId": null,
      "index": "b0t",
      "roundness": null,
      "seed": 835177816,
      "version": 583,
      "versionNonce": 965864134,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1766394383507,
      "link": null,
      "locked": false,
      "text": "Support for simple blocks (cube, stair, slab) and complex:\n\n// When building chunk mesh (WITH face culling):\nvar model = BlockModelRegistry.Get(\"cube\");\nif (model.MeshType == BlockMeshType.Simple)\n{\n    // Add only visible faces\n    for (int i = 0; i < model.Faces.Length; i++)\n    {\n        if (!IsFaceOccluded(blockPos, i))  // Check neighbor\n        {\n            AddFaceToMesh(model.Faces[i], blockPos);\n        }\n    }\n}\n\n\n\n//for custom models like brewing stands, do not have culling\n\n// When building chunk mesh (NO face culling):\nvar model = BlockModelRegistry.Get(\"brewing_stand\");\nif (model.MeshType == BlockMeshType.Complex)\n{\n    // Add entire mesh always (no culling)\n    AddCompleteModelToMesh(model, blockPos);\n}",
      "fontSize": 19.43019943019945,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Support for simple blocks (cube, stair, slab) and complex:\n\n// When building chunk mesh (WITH face culling):\nvar model = BlockModelRegistry.Get(\"cube\");\nif (model.MeshType == BlockMeshType.Simple)\n{\n    // Add only visible faces\n    for (int i = 0; i < model.Faces.Length; i++)\n    {\n        if (!IsFaceOccluded(blockPos, i))  // Check neighbor\n        {\n            AddFaceToMesh(model.Faces[i], blockPos);\n        }\n    }\n}\n\n\n\n//for custom models like brewing stands, do not have culling\n\n// When building chunk mesh (NO face culling):\nvar model = BlockModelRegistry.Get(\"brewing_stand\");\nif (model.MeshType == BlockMeshType.Complex)\n{\n    // Add entire mesh always (no culling)\n    AddCompleteModelToMesh(model, blockPos);\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
