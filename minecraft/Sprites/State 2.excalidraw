    {
      "id": "A9BK1XGmmSAsHUbBojKoA",
      "type": "text",
      "x": 1187.4444444444443,
      "y": -408.23015873015885,
      "width": 771.7794189453125,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aT",
      "roundness": null,
      "seed": 1841982971,
      "version": 72,
      "versionNonce": 796792795,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1766009792415,
      "link": null,
      "locked": false,
      "text": "The central singleton that stores:\n\nPlayer reference - tracks player position\nCubeManager reference - handles all voxel operations\nBlock definitions (Block_Data) - properties like hardness, drops, texture index\nItem definitions (Item_Data) - stack limits, textures\nAtlas dimensions - 12x8 grid for texture mapping\n\nKey Functions:\n\nget_player_pos() - returns player's world position\nget_block_stat() / get_item_stat() - retrieve block/item properties",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The central singleton that stores:\n\nPlayer reference - tracks player position\nCubeManager reference - handles all voxel operations\nBlock definitions (Block_Data) - properties like hardness, drops, texture index\nItem definitions (Item_Data) - stack limits, textures\nAtlas dimensions - 12x8 grid for texture mapping\n\nKey Functions:\n\nget_player_pos() - returns player's world position\nget_block_stat() / get_item_stat() - retrieve block/item properties",
      "autoResize": true,
      "lineHeight": 1.25
    },
