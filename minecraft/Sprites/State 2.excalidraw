      "link": null,
      "locked": false,
      "text": "Chunk to arrays:\n\ncreates the mesh based off of the voxel data (good)\n\nstores that created data into mesh data array(s) in chunk class (bad)\nstores that created data into collider data array in chunk class (bad)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Chunk to arrays:\n\ncreates the mesh based off of the voxel data (good)\n\nstores that created data into mesh data array(s) in chunk class (bad)\nstores that created data into collider data array in chunk class (bad)",
      "autoResize": true,
      "lineHeight": 1.25
    },
