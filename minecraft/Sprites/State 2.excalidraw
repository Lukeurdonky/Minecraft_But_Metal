    {
      "id": "-pz8qiGixyyLgZxD3DBQV",
      "type": "text",
      "x": 4633.706800756055,
      "y": 2896.9291647608643,
      "width": 977.6592407226562,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "Q8FxJwQWsbKadzfnmfF2x"
      ],
      "frameId": null,
      "index": "b0y",
      "roundness": null,
      "seed": 21006170,
      "version": 587,
      "versionNonce": 430687174,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1766392742978,
      "link": null,
      "locked": false,
      "text": "Step 1: Get Player's Chunk Position\nStep 2: Build List of Chunks That Should Be Active (in a sphere)\nStep 3: Sort Chunks by Distance\nStep 4: Process Each Chunk (Nearest First)\nStep 4.5: Add to load array if the chunk is real, in active array, and has been generated (load)\nStep 4.6: Add to generate array if chunk isn't real and the background thread has ended (generate)\nStep 5: Unload Chunks Out of Range",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 1: Get Player's Chunk Position\nStep 2: Build List of Chunks That Should Be Active (in a sphere)\nStep 3: Sort Chunks by Distance\nStep 4: Process Each Chunk (Nearest First)\nStep 4.5: Add to load array if the chunk is real, in active array, and has been generated (load)\nStep 4.6: Add to generate array if chunk isn't real and the background thread has ended (generate)\nStep 5: Unload Chunks Out of Range",
      "autoResize": true,
      "lineHeight": 1.25
    },
