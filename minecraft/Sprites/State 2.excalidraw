      "boundElements": [],
      "updated": 1766009466161,
      "link": null,
      "locked": false,
      "text": "Represents a single block with:\n\ntype - block name (e.g., \"stone\", \"grass\")\npos - world position (Vector3i)\nlocal_pos - position within chunk\nsides_ndx[6] - mesh vertex indices for each face (for updating visuals)\ncol_sides_ndx[6] - collision vertex indices for each face",
      "fontSize": 17.71428571428573,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Represents a single block with:\n\ntype - block name (e.g., \"stone\", \"grass\")\npos - world position (Vector3i)\nlocal_pos - position within chunk\nsides_ndx[6] - mesh vertex indices for each face (for updating visuals)\ncol_sides_ndx[6] - collision vertex indices for each face",
      "autoResize": true,
      "lineHeight": 1.25
    },
