      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "GwxhdmfzY7Vii0nX-lpU5"
      ],
      "frameId": null,
      "index": "b2U",
      "roundness": null,
      "seed": 134399110,
      "version": 107,
      "versionNonce": 555810778,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1766394579582,
      "link": null,
      "locked": false,
      "text": "create_chunk_data(vector3 position):\nvar chunk: Dictionary = {}\nfor x in range(CHUNK_SIZE.x):\n    for y in range(CHUNK_SIZE.y):\n        for z in range(CHUNK_SIZE.z):\n            var p = pos*CHUNK_SIZE.x + Vector3(x,y,z)\n            var c = null\n            \n            var abyss = Global.abyss_strength(p.x, p.z, p.y)\n            var layer = Global.abyss_layer(p.y)\n            \n            var surface_height = base_surface(p)\n            if p.y > surface_height:\n                    chunk[Vector3(x,y,z)] = null\n                    continue\n            \n            var cave_noise = noise.get_noise_3dv(p * Global.layer_noise_scale[layer])\n            var threshold = 0.6\n            threshold -= abyss * 0.8\n            threshold -= abs(p.y - Global.SURFACE_LEVEL) * 0.002\n            if cave_noise < threshold:\n                    c = Cube.new(\"stone\", p)\n                    \n            if c: chunk[Vector3(x,y,z)] = c \n            #else: chunk[x][y].append(null) # Air\nreturn chunk",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "create_chunk_data(vector3 position):\nvar chunk: Dictionary = {}\nfor x in range(CHUNK_SIZE.x):\n    for y in range(CHUNK_SIZE.y):\n        for z in range(CHUNK_SIZE.z):\n            var p = pos*CHUNK_SIZE.x + Vector3(x,y,z)\n            var c = null\n            \n            var abyss = Global.abyss_strength(p.x, p.z, p.y)\n            var layer = Global.abyss_layer(p.y)\n            \n            var surface_height = base_surface(p)\n            if p.y > surface_height:\n                    chunk[Vector3(x,y,z)] = null\n                    continue\n            \n            var cave_noise = noise.get_noise_3dv(p * Global.layer_noise_scale[layer])\n            var threshold = 0.6\n            threshold -= abyss * 0.8\n            threshold -= abs(p.y - Global.SURFACE_LEVEL) * 0.002\n            if cave_noise < threshold:\n                    c = Cube.new(\"stone\", p)\n                    \n            if c: chunk[Vector3(x,y,z)] = c \n            #else: chunk[x][y].append(null) # Air\nreturn chunk",
      "autoResize": true,
      "lineHeight": 1.25
    },
